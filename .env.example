# FinSight environment variables
# Copy to .env and fill in values

# Required for Week 2 LLM analysis (Google Gemini free tier)
GEMINI_API_KEY=your_key_here

# Optional: override default SQLite path
# FINSIGHT_DB_PATH=data/transcripts.db

# Optional: proxy for outbound requests (useful in corporate networks)
# HTTP_PROXY=
# HTTPS_PROXY=

# Future: API keys for enrichment services
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
